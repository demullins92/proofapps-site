<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TipTrackr — Reset Password</title>
  <style>
    body {
      background-color: #0f1b2d;
      color: #ffffff;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      text-align: center;
      padding: 32px;
      box-sizing: border-box;
    }
    h1 { font-size: 28px; margin-bottom: 12px; }
    p { color: #7a9bbf; font-size: 16px; line-height: 24px; }
  </style>
</head>
<body>
  <h1>🍸 TipTrackr</h1>
  <p>Redirecting you to reset your password...</p>
  <script>
    // Grab the full query string and fragment from Supabase
    const hash = window.location.hash;
    const search = window.location.search;
    const deepLink = 'tiptrackr://reset-password' + search + hash;
    window.location.replace(deepLink);
  </script>
</body>
</html>
